{
  "name": "backend-deephysio",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --watch src --ext js,mjs,cjs,json --ignore node_modules --ignore backups --ignore prisma src/server.js",
    "db:push": "node scripts/safe-migrate.js db push",
    "db:unsafe-push": "prisma db push --accept-data-loss",
    "db:migrate": "node scripts/safe-migrate.js migrate dev",
    "db:backup": "node scripts/prisma-backup.js",
    "db:studio": "prisma studio",
    "seed:integrations": "node scripts/seed_integrations.js",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "prisma": "^5.22.0",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
