generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                 @id @default(autoincrement())
  name                 String
  email                String              @unique
  password             String
  role                 Role
  allowed_menus        String?             @db.LongText
  allowed_permissions  String?             @db.LongText
  allowed_actions      String?             @db.LongText
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt
  resetPasswordExpires DateTime?
  resetPasswordToken   String?             @db.VarChar(255)
  appointments         Appointment[]       @relation("TherapistAppointments")
  clinical_notes       ClinicalNote[]      @relation("TherapistNotes")
  assigned_patients    Patient[]           @relation("AssignedTherapist")
  activity_logs        SystemActivityLog[]

  @@map("users")
}

model Patient {
  id                  Int                       @id @default(autoincrement())
  first_name          String                    @default("")
  last_name           String                    @default("")
  phone               String                    @unique
  email               String?                   @unique
  gender              Gender?
  date_of_birth       DateTime?
  address             String?
  patient_type        String                    @default("Normal")
  behaviour           String                    @default("green")
  is_active           Boolean                   @default(true)
  allow_sms           Boolean                   @default(true)
  allow_email         Boolean                   @default(true)
  allow_notifications Boolean                   @default(true)
  therapist_id        Int?
  is_deleted          Boolean                   @default(false)
  deleted_at          DateTime?
  created_at          DateTime                  @default(now())
  updated_at          DateTime                  @updatedAt
  appointments        Appointment[]             @relation("PatientAppointments")
  attachments         Attachment[]              @relation("PatientAttachments")
  body_charts         BodyChart[]               @relation("PatientBodyCharts")
  clinical_notes      ClinicalNote[]            @relation("PatientNotes")
  episodes            Episode[]                 @relation("PatientEpisodes")
  files               File[]                    @relation("PatientFiles")
  form_submissions    FormSubmission[]          @relation("PatientForms")
  invoices            Invoice[]                 @relation("PatientInvoices")
  emergency_contacts  PatientEmergencyContact[]
  medical_history     PatientMedicalHistory?
  assigned_therapist  User?                     @relation("AssignedTherapist", fields: [therapist_id], references: [id])
  payments            Payment[]                 @relation("PatientPayments")
  tasks               Task[]                    @relation("PatientTasks")
  waitlist_entries    Waitlist[]                @relation("PatientWaitlist")

  @@index([therapist_id])
  @@map("patients")
}

model BodyChart {
  id              Int      @id @default(autoincrement())
  patient_id      Int
  title           String
  image_url       String
  annotated_image String?  @db.LongText
  sort_order      Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  patient         Patient  @relation("PatientBodyCharts", fields: [patient_id], references: [id])

  @@index([patient_id])
  @@map("body_charts")
}

model File {
  id         Int      @id @default(autoincrement())
  patient_id Int
  file_name  String
  file_url   String
  file_type  String
  created_at DateTime @default(now())
  patient    Patient  @relation("PatientFiles", fields: [patient_id], references: [id])

  @@index([patient_id])
  @@map("files")
}

model Appointment {
  id               Int               @id @default(autoincrement())
  patient_id       Int
  therapist_id     Int
  appointment_date DateTime
  status           AppointmentStatus @default(scheduled)
  notes            String?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  checked_in_at    DateTime?
  service_id       Int?
  room             String?
  start_time       DateTime?
  end_time         DateTime?
  patient          Patient           @relation("PatientAppointments", fields: [patient_id], references: [id])
  service          Service?          @relation("ServiceAppointments", fields: [service_id], references: [id])
  therapist        User              @relation("TherapistAppointments", fields: [therapist_id], references: [id])

  @@index([patient_id])
  @@index([therapist_id])
  @@index([service_id])
  @@map("appointments")
}

model PatientMedicalHistory {
  id                  Int     @id @default(autoincrement())
  patient_id          Int     @unique
  existing_conditions String? @db.Text
  allergies           String? @db.Text
  chronic_diseases    String? @db.Text
  surgeries           String? @db.Text
  long_term_notes     String? @db.Text
  patient             Patient @relation(fields: [patient_id], references: [id])

  @@map("patient_medical_history")
}

model PatientEmergencyContact {
  id         Int     @id @default(autoincrement())
  patient_id Int
  name       String
  phone      String
  relation   String?
  patient    Patient @relation(fields: [patient_id], references: [id])

  @@index([patient_id])
  @@map("patient_emergency_contacts")
}

model Service {
  id           Int           @id @default(autoincrement())
  name         String
  category     String?
  duration     Int
  price        Decimal       @db.Decimal(10, 2)
  is_active    Boolean       @default(true)
  appointments Appointment[] @relation("ServiceAppointments")

  @@map("services")
}

model ClinicalNote {
  id              String   @id @default(uuid())
  patient_id      Int
  therapist_id    Int
  type            String
  date            DateTime
  status          String   @default("Draft")
  subjective      String?  @db.Text
  objective       String?  @db.Text
  assessment      String?  @db.Text
  plan            String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  dynamic_content String?  @db.LongText
  patient         Patient  @relation("PatientNotes", fields: [patient_id], references: [id])
  therapist       User     @relation("TherapistNotes", fields: [therapist_id], references: [id])

  @@index([patient_id])
  @@index([therapist_id])
  @@map("clinical_notes")
}

model Invoice {
  id         String        @id @default(uuid())
  patient_id Int
  date       DateTime
  subtotal   Decimal       @db.Decimal(10, 2)
  tax        Decimal       @db.Decimal(10, 2)
  total      Decimal       @db.Decimal(10, 2)
  status     InvoiceStatus @default(PENDING)
  notes      String?       @db.Text
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  items      InvoiceItem[] @relation("InvoiceItems")
  patient    Patient       @relation("PatientInvoices", fields: [patient_id], references: [id])
  payments   Payment[]     @relation("InvoicePayments")

  @@index([patient_id])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id         Int     @id @default(autoincrement())
  invoice_id String
  service    String
  rate       Decimal @db.Decimal(10, 2)
  qty        Int
  invoice    Invoice @relation("InvoiceItems", fields: [invoice_id], references: [id])

  @@index([invoice_id])
  @@map("invoice_items")
}

model Payment {
  id          String         @id @default(uuid())
  invoice_id  String?
  patient_id  Int
  amount      Decimal        @db.Decimal(10, 2)
  date        DateTime
  method      String?
  status      PaymentStatus? @default(COMPLETED)
  description String?        @db.Text
  created_at  DateTime       @default(now())
  invoice     Invoice?       @relation("InvoicePayments", fields: [invoice_id], references: [id])
  patient     Patient        @relation("PatientPayments", fields: [patient_id], references: [id])

  @@index([invoice_id])
  @@index([patient_id])
  @@map("payments")
}

model FormTemplate {
  id           Int              @id @default(autoincrement())
  name         String
  category     String
  fields       String           @db.LongText
  last_updated DateTime         @default(now()) @updatedAt
  is_active    Boolean          @default(true)
  submissions  FormSubmission[] @relation("TemplateSubmissions")

  @@map("form_templates")
}

model FormSubmission {
  id               Int          @id @default(autoincrement())
  patient_id       Int
  form_template_id Int
  responses        String       @db.LongText
  created_at       DateTime     @default(now())
  form_template    FormTemplate @relation("TemplateSubmissions", fields: [form_template_id], references: [id])
  patient          Patient      @relation("PatientForms", fields: [patient_id], references: [id])

  @@index([patient_id])
  @@index([form_template_id])
  @@map("form_submissions")
}

model Attachment {
  id          Int      @id @default(autoincrement())
  name        String
  patient_id  Int
  size        String
  type        String
  upload_date DateTime @default(now())
  patient     Patient  @relation("PatientAttachments", fields: [patient_id], references: [id])

  @@index([patient_id])
  @@map("attachments")
}

model Task {
  id          Int       @id @default(autoincrement())
  patient_id  Int
  title       String
  description String?   @db.Text
  status      String    @default("pending")
  due_date    DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  patient     Patient   @relation("PatientTasks", fields: [patient_id], references: [id])

  @@index([patient_id])
  @@map("tasks")
}

model Episode {
  id          Int       @id @default(autoincrement())
  patient_id  Int
  title       String
  description String?   @db.Text
  start_date  DateTime  @default(now())
  end_date    DateTime?
  created_at  DateTime  @default(now())
  patient     Patient   @relation("PatientEpisodes", fields: [patient_id], references: [id])

  @@index([patient_id])
  @@map("episodes")
}

model Waitlist {
  id             Int            @id @default(autoincrement())
  patient_id     Int?
  first_name     String
  last_name      String
  service        String
  preferred_date DateTime?
  preferred_time String?
  contact_number String
  priority       Priority       @default(MEDIUM)
  status         WaitlistStatus @default(WAITING)
  created_at     DateTime       @default(now())
  patient        Patient?       @relation("PatientWaitlist", fields: [patient_id], references: [id])

  @@index([patient_id])
  @@map("waitlist")
}

model ClinicalNoteTemplate {
  id         Int      @id @default(autoincrement())
  title      String
  category   String
  content    String   @db.LongText
  isCustom   Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("clinical_note_templates")
}

model GlobalSettings {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  value      String   @db.LongText
  updated_at DateTime @updatedAt

  @@map("global_settings")
}

model Integration {
  id                  Int                 @id @default(autoincrement())
  slug                String              @unique
  display_name        String
  category            String
  description         String?             @db.Text
  auth_type           IntegrationAuthType
  config_schema       String              @db.LongText
  adapter_key         String              @default("generic")
  is_active           Boolean             @default(true)
  supports_connect    Boolean             @default(true)
  supports_enable     Boolean             @default(true)
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  clinic_integrations ClinicIntegration[]

  @@map("integrations")
}

model ClinicIntegration {
  id                    Int                         @id @default(autoincrement())
  clinic_id             Int?
  integration_id        Int
  connection_status     IntegrationConnectionStatus @default(DISCONNECTED)
  is_enabled            Boolean                     @default(false)
  encrypted_credentials String?                     @db.LongText
  config                String?                     @db.LongText
  meta                  String?                     @db.LongText
  connected_at          DateTime?
  disconnected_at       DateTime?
  last_health_check_at  DateTime?
  created_at            DateTime                    @default(now())
  updated_at            DateTime                    @updatedAt
  integration           Integration                 @relation(fields: [integration_id], references: [id], onDelete: Cascade)

  @@unique([clinic_id, integration_id])
  @@index([integration_id])
  @@map("clinic_integrations")
}

model SystemActivityLog {
  id          Int              @id @default(autoincrement())
  user_id     Int?
  action      SystemActionType
  target_id   String?
  target_type String?
  details     String?
  meta        String?          @db.LongText
  created_at  DateTime         @default(now())
  user        User?            @relation(fields: [user_id], references: [id])

  @@index([created_at])
  @@index([user_id])
  @@map("system_activity_logs")
}

model communication_campaigns {
  id              Int      @id @default(autoincrement())
  channel         String   @db.VarChar(32)
  message         String   @db.LongText
  recipients_json String   @db.LongText
  status          String   @default("QUEUED") @db.VarChar(32)
  created_by      Int?
  created_at      DateTime @default(now())
}

model communication_messages {
  id              BigInt   @id @default(autoincrement())
  thread_id       Int
  patient_id      Int
  channel         String   @db.VarChar(32)
  direction       String   @db.VarChar(16)
  body            String   @db.LongText
  subject         String?
  delivery_status String   @default("PENDING") @db.VarChar(32)
  external_id     String?
  created_by      Int?
  created_at      DateTime @default(now())
  is_starred      Boolean  @default(false)
  is_deleted      Boolean  @default(false)

  @@index([patient_id], map: "idx_comm_messages_patient")
  @@index([thread_id], map: "idx_comm_messages_thread")
}

model communication_threads {
  id         Int      @id @default(autoincrement())
  patient_id Int
  channel    String   @db.VarChar(32)
  title      String?
  created_by Int?
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  @@index([patient_id, channel], map: "idx_comm_threads_patient_channel")
}

model telehealth_sessions {
  id           Int       @id @default(autoincrement())
  patient_id   Int
  therapist_id Int?
  provider     String    @db.VarChar(64)
  external_id  String
  join_url     String    @db.LongText
  status       String    @default("SCHEDULED") @db.VarChar(32)
  starts_at    DateTime?
  created_at   DateTime  @default(now())

  @@index([patient_id], map: "idx_telehealth_patient")
}

enum Role {
  admin
  therapist
  receptionist
  billing
}

enum Gender {
  male
  female
  other
}

enum AppointmentStatus {
  scheduled
  confirmed
  checked_in
  in_progress
  completed
  cancelled
  no_show
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum WaitlistStatus {
  WAITING
  CONFIRMED
  NO_SHOW
}

enum IntegrationAuthType {
  API_KEY
  TOKEN
  OAUTH2
  WEBHOOK
  NONE
}

enum IntegrationConnectionStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
  REFUNDED
}

enum SystemActionType {
  LOGIN
  CREATE_APPOINTMENT
  UPDATE_APPOINTMENT
  CREATE_PATIENT
  UPDATE_PATIENT
  CREATE_NOTE
  UPDATE_NOTE
  CREATE_INVOICE
  PAY_INVOICE
  UPDATE_SETTINGS
}
